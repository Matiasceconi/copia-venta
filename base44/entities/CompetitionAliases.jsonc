{
  "name": "CompetitionAliases",
  "type": "object",
  "properties": {
    "organization_id": {
      "type": "string",
      "description": "ID de la organizaci\u00f3n (club) propietaria del registro"
    },
    "competition_id": {
      "type": "string",
      "description": "ID de la competencia oficial"
    },
    "alias": {
      "type": "string",
      "description": "Texto alternativo recibido desde importaciones o registros hist\u00f3ricos"
    },
    "normalized_alias": {
      "type": "string",
      "description": "Alias normalizado para coincidencias"
    },
    "active": {
      "type": "boolean",
      "default": true,
      "description": "Si el alias est\u00e1 activo"
    }
  },
  "required": [
    "organization_id",
    "competition_id",
    "alias",
    "normalized_alias"
  ]
}